{
  "paths": {
    "src": "../src",
    "content": "../content",
    "html": "../html",
    "rulesFile": "rules/fedramp-consolidated-rules.json",
    "template": "templates/template.hbs",
    "partials": "templates/partials",
    "zensicalConfig": "../zensical.toml"
  },
  "pictographs": {
    "source": {
      "machine": ":lucide-computer:{ .machine }",
      "person": ":lucide-person-standing:{ .person }"
    },
    "status": {
      "stable": ":lucide-book-open-check:{ .stable }",
      "placeholder": ":lucide-pencil:{ .placeholder }",
      "empty": ":lucide-circle-slash:{ .empty }"
    }
  },
  "generated": {
    "manifest": ".generated-markdown.json",
    "definitionDocuments": [
      {
        "id": "fedramp-definitions",
        "title": "FedRAMP Definitions",
        "output": "definitions.md",
        "status": "stable",
        "includeEffectiveDates": false,
        "source": {
          "collection": "FRD",
          "types": ["20x", "rev5"],
          "includeBoth": true,
          "bothPosition": "first"
        }
      }
    ],
    "ksiDocuments": [
      {
        "id": "provider-20x-key-security-indicators",
        "output": "providers/20x/key-security-indicators/{KSI}.md",
        "status": "stable",
        "definitionsHref": "../../../definitions/",
        "source": {
          "collection": "KSI",
          "themes": "ALL"
        }
      }
    ],
    "deadlineDocuments": [
      {
        "id": "provider-important-deadlines",
        "title": "Important Deadlines",
        "output": "providers/updating/deadlines/{type}.md",
        "status": "stable",
        "template": "templates/deadlines.hbs",
        "source": {
          "collection": "FRR",
          "documents": [
            "MKT",
            "FRC",
            "MAS",
            "CDS",
            "SCG",
            "UCM",
            "FSI",
            "ICP",
            "SCN",
            "VDR",
            "CCM"
          ],
          "types": ["20x", "rev5"]
        }
      }
    ],
    "ruleDocuments": [
      {
        "id": "fedramp-responsibilities",
        "output": "responsibilities/{FRR}.md",
        "outputMode": "documents",
        "status": "stable",
        "definitionsHref": "../definitions/",
        "rulesHref": "../",
        "emptyBehavior": "skip",
        "includeEffectiveDates": false,
        "source": {
          "collection": "FRR",
          "documents": "ALL",
          "types": ["20x", "rev5"],
          "affects": ["FedRAMP"],
          "includeBoth": true,
          "bothPosition": "first"
        }
      },
      {
        "id": "agency-specific-rules",
        "output": "agencies/rules/{FRR}.md",
        "outputMode": "documents",
        "status": "placeholder",
        "definitionsHref": "../../definitions/",
        "rulesHref": "../../",
        "emptyBehavior": "skip",
        "includeEffectiveDates": false,
        "source": {
          "collection": "FRR",
          "documents": "ALL",
          "types": ["20x", "rev5"],
          "affects": ["Agencies"],
          "includeBoth": true,
          "bothPosition": "first"
        }
      },
